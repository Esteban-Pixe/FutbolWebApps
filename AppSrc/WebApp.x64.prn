37969>>>    Procedure SetActionButtons
37972>>>        tWebNavigateData NavigateData
37972>>>        tWebNavigateData NavigateData
37972>>>        Boolean bHasRecord
37972>>>        Handle hoDD
37972>>>
37972>>>        Get Server to hoDD
37973>>>        Get GetNavigateData to NavigateData
37974>>>        Get HasRecord of hoDD to bHasRecord
37975>>>
37975>>>        // let's hide all buttons and then Show the ones we want
37975>>>        WebSet pbRender of oEditBtn to False
37976>>>        WebSet pbRender of oSaveBtn to False
37977>>>        WebSet pbRender of oCancelChangesBtn to False
37978>>>        WebSet pbRender of oDeleteBtn to False
37979>>>
37979>>>        If (NavigateData.bReadOnly) Begin
37981>>>            WebSet pbRender of oEditBtn to True
37982>>>        End
37982>>>>
37982>>>        Else Begin
37983>>>            WebSet pbRender of oSaveBtn to True
37984>>>            WebSet pbRender of oCancelChangesBtn to True
37985>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37986>>>        End
37986>>>>
37986>>>    End_Procedure
37987>>>
37987>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
37990>>>        // Close after save
37990>>>        Send NavigateClose Self
37991>>>    End_Procedure
37992>>>
37992>>>    // this will close the view after a delete
37992>>>    Procedure OnViewDeleted Handle hoDDO
37995>>>        Send NavigateClose Self
37996>>>    End_Procedure
