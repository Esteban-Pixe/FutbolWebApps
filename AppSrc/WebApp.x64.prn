39149>>>    Procedure SetActionButtons
39152>>>        tWebNavigateData NavigateData
39152>>>        tWebNavigateData NavigateData
39152>>>        Boolean bHasRecord
39152>>>        Handle hoDD
39152>>>
39152>>>        Get Server to hoDD
39153>>>        Get GetNavigateData to NavigateData
39154>>>        Get HasRecord of hoDD to bHasRecord
39155>>>
39155>>>        // let's hide all buttons and then Show the ones we want
39155>>>        WebSet pbRender of oEditBtn to False
39156>>>        WebSet pbRender of oSaveBtn to False
39157>>>        WebSet pbRender of oCancelChangesBtn to False
39158>>>        WebSet pbRender of oDeleteBtn to False
39159>>>        WebSet pbRender of oBackBtn to True
39160>>>
39160>>>        If (NavigateData.bReadOnly) Begin
39162>>>            WebSet pbRender of oEditBtn to True
39163>>>        End
39163>>>>
39163>>>        Else Begin
39164>>>            WebSet pbRender of oSaveBtn to True
39165>>>            WebSet pbRender of oCancelChangesBtn to True
39166>>>            WebSet pbRender of oDeleteBtn to bHasRecord
39167>>>        End
39167>>>>
39167>>>    End_Procedure
39168>>>
39168>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
39171>>>        // Close after save
39171>>>        Send NavigateClose Self
39172>>>    End_Procedure
39173>>>
