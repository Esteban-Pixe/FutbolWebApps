38335>>>    Procedure SetActionButtons
38338>>>        tWebNavigateData NavigateData
38338>>>        tWebNavigateData NavigateData
38338>>>        Boolean bHasRecord
38338>>>        Handle hoDD
38338>>>
38338>>>        Get Server to hoDD
38339>>>        Get GetNavigateData to NavigateData
38340>>>        Get HasRecord of hoDD to bHasRecord
38341>>>
38341>>>        // let's hide all buttons and then Show the ones we want
38341>>>        WebSet pbRender of oEditBtn to False
38342>>>        WebSet pbRender of oSaveBtn to False
38343>>>        WebSet pbRender of oCancelChangesBtn to False
38344>>>        WebSet pbRender of oDeleteBtn to False
38345>>>
38345>>>        If (NavigateData.bReadOnly) Begin
38347>>>            WebSet pbRender of oEditBtn to True
38348>>>        End
38348>>>>
38348>>>        Else Begin
38349>>>            WebSet pbRender of oSaveBtn to True
38350>>>            WebSet pbRender of oCancelChangesBtn to True
38351>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38352>>>        End
38352>>>>
38352>>>    End_Procedure
38353>>>
