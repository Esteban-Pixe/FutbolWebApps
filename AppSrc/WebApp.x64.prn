37611>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
37614>>>        Case Begin
37614>>>            Case (NavigateData.eNavigateType = nfFromMain)
37616>>>                // If from main, this is a propbably a main file Select to Zoom.
37616>>>                Case Break
37617>>>
37617>>>            Case (NavigateData.eNavigateType = nfFromParent)
37620>>>                // If from parent, this is a constrained drill down.
37620>>>                Case Break
37621>>>
37621>>>            Case (NavigateData.eNavigateType = nfFromChild)
37624>>>                // If from child, this is a probably a parent Zoom from a Zoom.
37624>>>                Case Break
37625>>>
37625>>>            Case Else // must be nfUndefined
37625>>>
37625>>>        Case End
37625>>>
37625>>>        Send SetActionButtons
37626>>>
37626>>>    End_Procedure
