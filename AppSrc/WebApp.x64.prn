39183>>>                Case Break
39184>>>
39184>>>            Case (NavigateData.eNavigateType = nfFromParent)
39187>>>                // If from parent, this is a constrained drill down.
39187>>>                Case Break
39188>>>
39188>>>            Case (NavigateData.eNavigateType = nfFromChild)
39191>>>                // If from child, this is a probably a parent Zoom from a Zoom.
39191>>>                Case Break
39192>>>
39192>>>            Case Else // must be nfUndefined
39192>>>
39192>>>        Case End
39192>>>
39192>>>        Send SetActionButtons
39193>>>
39193>>>    End_Procedure
