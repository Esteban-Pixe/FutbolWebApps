38002>>>                Case Break
38003>>>
38003>>>            Case (NavigateData.eNavigateType = nfFromParent)
38006>>>                // If from parent, this is a constrained drill down.
38006>>>                Case Break
38007>>>
38007>>>            Case (NavigateData.eNavigateType = nfFromChild)
38010>>>                // If from child, this is a probably a parent Zoom from a Zoom.
38010>>>                Case Break
38011>>>
38011>>>            Case Else // must be nfUndefined
38011>>>
38011>>>        Case End
38011>>>
38011>>>        Send SetActionButtons
38012>>>
38012>>>    End_Procedure
38013>>>
38013>>>End_Object 
