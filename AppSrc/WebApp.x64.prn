36928>>>>>Class cWebSessionManagerStandard is a cWebSessionManager
36929>>>>>    
36929>>>>>    Procedure Construct_Object
36931>>>>>        Handle hoObj
36931>>>>>        
36931>>>>>        Forward Send Construct_Object
36933>>>>>        
36933>>>>>        Set pbSessionCookieHttpOnly to True
36934>>>>>        
36934>>>>>        Property Handle phoUserDD 0      // Handle to the WebAppUser DDO
36935>>>>>        Property Handle phoSessionDD 0   // Handle to the WebAppSession DDO  
36936>>>>>        Property Handle phoCrypto 0      // Handle to the PasswordHasher
36937>>>>>        
36937>>>>>        Get CreateNamed (RefClass(cWebAppUserDataDictionary)) 'oUserDD' to hoObj
36938>>>>>        Set phoUserDD to hoObj
36939>>>>>        
36939>>>>>        Get CreateNamed (RefClass(cWebAppSessionDataDictionary)) 'oSessionDD' to hoObj
36940>>>>>        Set DDO_Server of hoObj to (phoUserDD(Self))
36941>>>>>        Set phoSessionDD to hoObj
36942>>>>>        
36942>>>>>        Property Handle phoCrypto 0   // Handle to the Cryptographer
36943>>>>>        Get CreateNamed (RefClass(cPasswordHasher)) 'oCrypto' to hoObj
36944>>>>>        Set phoCrypto to hoObj
36945>>>>>        
36945>>>>>        Property Boolean pbPasswordHashing True
36946>>>>>        
36946>>>>>        Property Boolean pbCreatingNewSession False
36947>>>>>        Property String psLoginName
36948>>>>>        Property String psUserName ""
36949>>>>>        Property Integer piUserRights 0
36950>>>>>    End_Procedure
36951>>>>>    
36951>>>>>    Procedure End_Construct_Object
36953>>>>>        Forward Send End_Construct_Object
36955>>>>>        
36955>>>>>        Handle hoCrypto
36955>>>>>        Integer iFieldLen
36955>>>>>        If (pbPasswordHashing(Self)) Begin
36957>>>>>            Get phoCrypto to hoCrypto
36958>>>>>            Get_Attribute DF_FIELD_LENGTH of (RefTable(WebAppUser)) (RefTable(WebAppUser.Password)) to iFieldLen
36961>>>>>            If (iFieldLen < (RequiredBufferSize(hoCrypto) + 3)) Begin
36963>>>>>                Error DFERR_PROGRAM "The password field of WebAppUser is not large enough (128)"
36964>>>>>>
36964>>>>>            End
36964>>>>>>
36964>>>>>        End
36964>>>>>>
36964>>>>>    End_Procedure
36965>>>>>    
36965>>>>>    Function CreateSession String sRemoteAddress Returns String
36967>>>>>        String sSessionKey
36967>>>>>        Integer iErr
36967>>>>>        Boolean bLogWebSession
36967>>>>>        Handle hoSessionDD       
36967>>>>>        Get phoSessionDD to hoSessionDD
36968>>>>>        
36968>>>>>        //  Get session key
36968>>>>>        Forward Get CreateSession sRemoteAddress to sSessionKey
36970>>>>>        
36970>>>>>        Get pbLogWebSession to bLogWebSession
36971>>>>>        If not bLogWebSession Begin
36973>>>>>            Function_Return sSessionKey        
36974>>>>>        End
36974>>>>>>
36974>>>>>
36974>>>>>        //  Store session
36974>>>>>        Send Clear of hoSessionDD
36975>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.SessionKey to sSessionKey
36976>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.RemoteAddress to sRemoteAddress
36977>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.Active to "Y"
36978>>>>>        Get Request_Validate of hoSessionDD to iErr
36979>>>>>        If (iErr) Begin
36981>>>>>            // this should not happen. If it does its a programming error
36981>>>>>            Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
36982>>>>>>
36982>>>>>            Function_Return ""
36983>>>>>        End
36983>>>>>>
36983>>>>>        Send Request_Save of hoSessionDD
36984>>>>>        If (Err) Begin
36986>>>>>            // this shouldn't happen, if it does likely a duplicate session key issue, even through request_save already gave an error we give another one to make tracking down easier
36986>>>>>            Error DFERR_PROGRAM C_$WebAppSessionSaveFailed
36987>>>>>>
36987>>>>>            Function_Return ""
36988>>>>>        End
36988>>>>>>
36988>>>>>       
36988>>>>>        Function_Return sSessionKey        
36989>>>>>    End_Function
36990>>>>>    
36990>>>>>    Function ValidateSession String sSessionKey Boolean bOptLoadWebApp Returns Boolean
36992>>>>>        DateTime dtLastAccess dtCurrent
36992>>>>>        TimeSpan tsDiff
36992>>>>>        Integer iErr iSessionTimeout iSpanMinutes
36992>>>>>        Boolean bResult bCreatingNewSession
36992>>>>>        Boolean bLogWebSession bLoadWebApp
36992>>>>>        Integer eLoginMode
36992>>>>>        String sTime
36992>>>>>        Handle hoSessionDD hoUserDD       
36992>>>>>        
36992>>>>>        Move False to bLoadWebApp
36993>>>>>        If (num_arguments >= 2) Begin
36995>>>>>            Move bOptLoadWebApp to bLoadWebApp
36996>>>>>        End
36996>>>>>>
36996>>>>>        
36996>>>>>        Get phoSessionDD to hoSessionDD
36997>>>>>        Get phoUserDD to hoUserDD
36998>>>>>        
36998>>>>>        Get pbLogWebSession to bLogWebSession
36999>>>>>        Get peLoginMode to eLoginMode
37000>>>>>        
37000>>>>>        // for this object, you can only disable logging if login completely is disabled
37000>>>>>        If (not(bLogWebSession) and (eLoginMode<>lmLoginNone)) Begin
37002>>>>>            Error DFERR_PROGRAM C_$WebSessionLoggingMustBeEnabled
37003>>>>>>
37003>>>>>            Function_Return False
37004>>>>>        End
37004>>>>>>
37004>>>>>
37004>>>>>        //  Clear session properties
37004>>>>>        Set psSessionKey to ""
37005>>>>>        Send UpdateSessionProperties True
37006>>>>>        
37006>>>>>        If not bLogWebSession Begin
37008>>>>>            Forward Get ValidateSession sSessionKey to bResult
37010>>>>>            Function_Return bResult
37011>>>>>        End        
37011>>>>>>
37011>>>>>        
37011>>>>>        Move False to bResult
37012>>>>>        Get piSessionTimeout to iSessionTimeout 
37013>>>>>        
37013>>>>>        //  Check if session exists
37013>>>>>        Send Clear of hoSessionDD
37014>>>>>        Move sSessionKey to WebAppSession.SessionKey
37015>>>>>        Send Find of hoSessionDD EQ Index.1
37016>>>>>            
37016>>>>>        If (Found) Begin
37018>>>>>            //  Calculate timespan between now and last access time
37018>>>>>            Move (CurrentDateTime()) to dtCurrent
37019>>>>>            Move WebAppSession.LastAccessDate to dtLastAccess
37020>>>>>            Get StringToTime of hoSessionDD dtLastAccess WebAppSession.LastAccessTime to dtLastAccess
37021>>>>>            Move (dtCurrent - dtLastAccess) to tsDiff
37022>>>>>            Move (SpanTotalMinutes(tsDiff)) to iSpanMinutes
37023>>>>>            
37023>>>>>            //  Check if session didn't time out
37023>>>>>            If (IsDateValid(dtLastAccess) and (iSessionTimeout <= 0 or (iSpanMinutes < iSessionTimeout)) and WebAppSession.Active = "Y") Begin
37025>>>>>                Forward Get ValidateSession sSessionKey to bResult
37027>>>>>                   
37027>>>>>                If (bResult) Begin
37029>>>>>                    //  Update session record
37029>>>>>                    Get TimeToString of hoSessionDD dtCurrent to sTime 
37030>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessDate to dtCurrent
37031>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessTime to sTime
37032>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.UseCount to (WebAppSession.UseCount + 1)
37033>>>>>                    Get Request_Validate of hoSessionDD to iErr
37034>>>>>                    If (iErr) Begin
37036>>>>>                        // this should not happen. If it does its a programming error
37036>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37037>>>>>>
37037>>>>>                        Function_Return False
37038>>>>>                    End
37038>>>>>>
37038>>>>>                    Send Request_Save of hoSessionDD
37039>>>>>                    
37039>>>>>                    //  Update user properties
37039>>>>>                    Send UpdateSessionProperties False
37040>>>>>                End
37040>>>>>>
37040>>>>>            End
37040>>>>>>
37040>>>>>            Else Begin
37041>>>>>                // Test the Creating New Session Flag to protect against infinite recursion....
37041>>>>>                Get pbCreatingNewSession to bCreatingNewSession
37042>>>>>                
37042>>>>>                If (not(bCreatingNewSession)) Begin
37044>>>>>                    If (not(bLoadWebApp)) Begin
37046>>>>>                        Move False to bResult   //  We can only continue immediately if we were loading the webapp, other operations are not allowed!
37047>>>>>                        Error DFERR_WEBAPP_SESSION_TIMEOUT "Your application session has timed out or is inactive, please login again."
37048>>>>>>
37048>>>>>                        Send NavigateRefresh of ghoWebApp          // refresh the WebApp at the client (triggers a login)
37049>>>>>                    End
37049>>>>>>
37049>>>>>                    Else Begin
37050>>>>>                        Set pbCreatingNewSession to True                    
37051>>>>>                        Get RecreateSession of ghoWebApp to bResult 
37052>>>>>                        Set pbCreatingNewSession to False                        
37053>>>>>                    End
37053>>>>>>
37053>>>>>                End
37053>>>>>>
37053>>>>>            End
37053>>>>>>
37053>>>>>        End
37053>>>>>>
37053>>>>>        Else Begin
37054>>>>>            Error DFERR_WEBAPP_BAD_SESSION_KEY "Session key not known (reload page to recreate session)"
37055>>>>>>
37055>>>>>        End
37055>>>>>>
37055>>>>>        
37055>>>>>        Function_Return bResult
37056>>>>>    End_Function
37057>>>>>    
37057>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
37059>>>>>        If (not(pbPasswordHashing(Self))) Begin
37061>>>>>            Move sPassword to sHash
37062>>>>>            Function_Return True
37063>>>>>        End
37063>>>>>>
37063>>>>>        
37063>>>>>        If (not(CreatePasswordHash(phoCrypto(Self), sPassword, &sHash))) Begin
37065>>>>>            Function_Return False
37066>>>>>        End
37066>>>>>>
37066>>>>>        Move ("V1$" + sHash) to sHash
37067>>>>>        Function_Return True
37068>>>>>    End_Function
37069>>>>>    
37069>>>>>    Function VerifyPasswordHash String sUserPassword String sEnteredPassword Boolean ByRef bShouldUpgrade Returns Boolean
37071>>>>>        If (not(pbPasswordHashing(Self))) Begin
37073>>>>>            Move False to bShouldUpgrade
37074>>>>>            Function_Return (sUserPassword = sEnteredPassword)
37075>>>>>        End
37075>>>>>>
37075>>>>>        
37075>>>>>        String sVersion
37075>>>>>        Move (Left(sUserPassword, 3)) to sVersion
37076>>>>>        If (sVersion = "V1$") Begin
37078>>>>>            If (num_arguments > 2) Move False to bShouldUpgrade
37081>>>>>            Function_Return (VerifyPasswordHash(phoCrypto(Self), sEnteredPassword, Right(sUserPassword, Length(sUserPassword) - 3)))
37082>>>>>        End
37082>>>>>>
37082>>>>>        Else Begin
37083>>>>>            If (num_arguments > 2) Move True to bShouldUpgrade
37086>>>>>            Function_Return False
37087>>>>>        End
37087>>>>>>
37087>>>>>    End_Function
37088>>>>>    
37088>>>>>    Function UserRegister String sLoginName String sPassword Returns Boolean
37090>>>>>        Handle hoUserDD
37090>>>>>        Integer iErr
37090>>>>>        Get phoUserDD to hoUserDD
37091>>>>>        
37091>>>>>        //  Find the user
37091>>>>>        Send Clear of hoUserDD
37092>>>>>        Move sLoginName to WebAppUser.LoginName
37093>>>>>        Send Find of hoUserDD EQ Index.1
37094>>>>>        If (Found) Begin
37096>>>>>            Send Clear of hoUserDD
37097>>>>>            Function_Return False
37098>>>>>        End
37098>>>>>>
37098>>>>>        
37098>>>>>        Send Clear of hoUserDD
37099>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.FullName to sLoginName
37100>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.LoginName to sLoginName
37101>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37103>>>>>            Send Clear of hoUserDD
37104>>>>>            Function_Return False
37105>>>>>        End
37105>>>>>>
37105>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37106>>>>>        Get Request_Validate of hoUserDD to iErr
37107>>>>>        If (iErr) Begin
37109>>>>>            Send Clear of hoUserDD
37110>>>>>            Function_Return False
37111>>>>>        End
37111>>>>>>
37111>>>>>        
37111>>>>>        Send Request_Save of hoUserDD
37112>>>>>        Function_Return (not(Err))
37113>>>>>    End_Function
37114>>>>>    
37114>>>>>    Function UserLogin String sLoginName String sPassword Returns Boolean
37116>>>>>        String sSessionKey sUserPassword
37116>>>>>        Handle hoSessionDD hoUserDD
37116>>>>>        Boolean bMatch bUpgrade
37116>>>>>        
37116>>>>>        Get phoSessionDD to hoSessionDD
37117>>>>>        Get phoUserDD to hoUserDD
37118>>>>>        Integer iErr eLoginMode
37118>>>>>        
37118>>>>>        // Refind session record
37118>>>>>        Get psSessionKey to sSessionKey
37119>>>>>        Send Clear of hoSessionDD
37120>>>>>        Move sSessionKey to WebAppSession.SessionKey
37121>>>>>        Send Find of hoSessionDD EQ Index.1
37122>>>>>        
37122>>>>>        If (Found and WebAppSession.SessionKey = sSessionKey) Begin
37124>>>>>            Get peLoginMode to eLoginMode
37125>>>>>            
37125>>>>>            //  Find the user
37125>>>>>            Move sLoginName to WebAppUser.LoginName
37126>>>>>            Send Find of hoUserDD EQ Index.1
37127>>>>>            
37127>>>>>            // Check username and password
37127>>>>>            If (Found and (Lowercase(sLoginName) = Lowercase(Trim(WebAppUser.LoginName)))) Begin
37129>>>>>                Get Field_Current_Value of hoUserDD Field WebAppUser.Password to sUserPassword
37130>>>>>                Get VerifyPasswordHash (Trim(sUserPassword)) (Trim(sPassword)) (&bUpgrade) to bMatch
37131>>>>>                
37131>>>>>                If (bMatch) Begin
37133>>>>>                    // Store the login
37133>>>>>                    If (bUpgrade) Begin
37135>>>>>                        Get CreatePasswordHash (Trim(sPassword)) (&sPassword) to bUpgrade
37136>>>>>                        If (bUpgrade) Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37139>>>>>                    End
37139>>>>>>
37139>>>>>                    Set Field_Changed_Value of hoUserDD Field WebAppUser.LastLogin to (CurrentDateTime())
37140>>>>>                    Get Request_Validate of hoSessionDD to iErr
37141>>>>>                    If (iErr) Begin
37143>>>>>                        // this should not happen. If it does its a programming error
37143>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37144>>>>>>
37144>>>>>                        Function_Return False
37145>>>>>                    End
37145>>>>>>
37145>>>>>                    
37145>>>>>                    Send Request_Save of hoSessionDD
37146>>>>>                    
37146>>>>>                    // Update session properties
37146>>>>>                    Send UpdateSessionProperties False
37147>>>>>                    Send NotifyChangeRights
37148>>>>>                    Function_Return True
37149>>>>>                End
37149>>>>>>
37149>>>>>                Else Begin
37150>>>>>                    //  We should rely directly on this buffer elsewhere but just be sure
37150>>>>>                    Send Clear of hoUserDD
37151>>>>>                End
37151>>>>>>
37151>>>>>            End
37151>>>>>>
37151>>>>>            Else Begin
37152>>>>>                // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37152>>>>>                Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37153>>>>>            End
37153>>>>>>
37153>>>>>        End
37153>>>>>>
37153>>>>>        Else Begin
37154>>>>>            // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37154>>>>>            Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37155>>>>>        End
37155>>>>>>
37155>>>>>          
37155>>>>>        Function_Return False
37156>>>>>    End_Function
37157>>>>>    
37157>>>>>    Function SetUserPassword String sLoginName String sPassword Returns Boolean
37159>>>>>        Handle hoUserDD
37159>>>>>        Integer iErr
37159>>>>>        Get phoUserDD to hoUserDD
37160>>>>>        
37160>>>>>        //  Find the user
37160>>>>>        Send Clear of hoUserDD
37161>>>>>        Move sLoginName to WebAppUser.LoginName
37162>>>>>        Send Find of hoUserDD EQ Index.1
37163>>>>>        If (not(Found)) Begin
37165>>>>>            Send Clear of hoUserDD
37166>>>>>            Function_Return False
37167>>>>>        End
37167>>>>>>
37167>>>>>        
37167>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37169>>>>>            Send Clear of hoUserDD
37170>>>>>            Function_Return False
37171>>>>>        End
37171>>>>>>
37171>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37172>>>>>        Get Request_Validate of hoUserDD to iErr
37173>>>>>        If (iErr) Begin
37175>>>>>            Send Clear of hoUserDD
37176>>>>>            Function_Return False
37177>>>>>        End
37177>>>>>>
37177>>>>>        
37177>>>>>        Send Request_Save of hoUserDD
37178>>>>>        Function_Return (not(Err))
37179>>>>>    End_Function
37180>>>>>    
37180>>>>>    Function IsLoggedIn Returns Boolean
37182>>>>>        String sLoginName
37182>>>>>        Boolean bLogWebSession bLoggedIn
37182>>>>>        
37182>>>>>        Get pbLogWebSession to bLogWebSession
37183>>>>>        If not bLogWebSession Begin
37185>>>>>            Forward Get IsLoggedIn to bLoggedIn
37187>>>>>            Function_Return bLoggedIn
37188>>>>>        End
37188>>>>>>
37188>>>>>        
37188>>>>>        Get psLoginName to sLoginName
37189>>>>>        
37189>>>>>        Function_Return (sLoginName <> "")
37190>>>>>    End_Function
37191>>>>>    
37191>>>>>    
37191>>>>>    //
37191>>>>>    // This procedure is called when validating a session and after logging in. Its purpose is to 
37191>>>>>    // update properties based on the session and user data. Augment this function to update 
37191>>>>>    // properties based on the session / user table. Note that WebAppUser and WebAppSession contain
37191>>>>>    // the right records when this procedure is called.
37191>>>>>    //
37191>>>>>    // Params:
37191>>>>>    //      bClear   True if the procedure is called before session validation to clear properties.
37191>>>>>    //
37191>>>>>    Procedure UpdateSessionProperties Boolean bClear
37193>>>>>        Handle hoUserDD
37193>>>>>        
37193>>>>>        Get phoUserDD to hoUserDD
37194>>>>>        
37194>>>>>        //  Update user properties
37194>>>>>        If (not(bClear) and HasRecord(hoUserDD)) Begin
37196>>>>>            Set psUsername to (Trim(WebAppUser.FullName))
37197>>>>>            Set psLoginName to (Trim(WebAppUser.LoginName))
37198>>>>>            Set piUserRights to WebAppUser.Rights
37199>>>>>            
37199>>>>>            Send OnSessionPropertiesSet 
37200>>>>>        End
37200>>>>>>
37200>>>>>        Else Begin
37201>>>>>            Set psUsername to ""
37202>>>>>            Set psLoginName to ""
37203>>>>>            Set piUserRights to 0
37204>>>>>            
37204>>>>>            Send OnSessionPropertiesClear
37205>>>>>        End
37205>>>>>>
37205>>>>>    End_Procedure
37206>>>>>    
37206>>>>>    Procedure OnSessionPropertiesSet
37208>>>>>        //  Empty event stub
37208>>>>>    End_Procedure
37209>>>>>    
37209>>>>>    Procedure OnSessionPropertiesClear
37211>>>>>        //  Empty event stub
37211>>>>>    End_Procedure
37212>>>>>    
37212>>>>>    Procedure EndSession
37214>>>>>        Integer iErr
37214>>>>>        Boolean bLogWebSession
37214>>>>>        Handle hoSessionDD       
37214>>>>>        
37214>>>>>        Get phoSessionDD to hoSessionDD
37215>>>>>        Get pbLogWebSession to bLogWebSession
37216>>>>>        If not bLogWebSession Begin
37218>>>>>            Forward Send EndSession
37220>>>>>            Procedure_Return
37221>>>>>        End
37221>>>>>>
37221>>>>>            
37221>>>>>        //  Check if session exists
37221>>>>>        Send Clear of hoSessionDD
37222>>>>>        Get psSessionKey to WebAppSession.SessionKey
37223>>>>>        
37223>>>>>        Send Find of hoSessionDD EQ Index.1
37224>>>>>        If (Found) Begin
37226>>>>>            Set Field_Changed_Value of hoSessionDD Field WebAppSession.Active to "N"
37227>>>>>            Get Request_Validate of hoSessionDD to iErr
37228>>>>>            If (iErr) Begin
37230>>>>>                // this should not happen. If it does its a programming error
37230>>>>>                Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37231>>>>>>
37231>>>>>                Procedure_Return
37232>>>>>            End
37232>>>>>>
37232>>>>>            Send Request_Save of hoSessionDD
37233>>>>>        End
37233>>>>>>
37233>>>>>    End_Procedure
37234>>>>>
37234>>>>>End_Class
37235>>>>>
