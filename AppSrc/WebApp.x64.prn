37757>>>        Case Begin
37757>>>            Case (NavigateData.eNavigateType = nfFromMain)
37759>>>                // If from main, this is a propbably a main file Select to Zoom.
37759>>>                Case Break
37760>>>
37760>>>            Case (NavigateData.eNavigateType = nfFromParent)
37763>>>                // If from parent, this is a constrained drill down.
37763>>>                Case Break
37764>>>
37764>>>            Case (NavigateData.eNavigateType = nfFromChild)
37767>>>                // If from child, this is a probably a parent Zoom from a Zoom.
37767>>>                Case Break
37768>>>
37768>>>            Case Else // must be nfUndefined
37768>>>
37768>>>        Case End
37768>>>
37768>>>        Send SetActionButtons
37769>>>
37769>>>    End_Procedure
