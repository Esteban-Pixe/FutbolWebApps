38368>>>                Case Break
38369>>>
38369>>>            Case (NavigateData.eNavigateType = nfFromParent)
38372>>>                // If from parent, this is a constrained drill down.
38372>>>                Case Break
38373>>>
38373>>>            Case (NavigateData.eNavigateType = nfFromChild)
38376>>>                // If from child, this is a probably a parent Zoom from a Zoom.
38376>>>                Case Break
38377>>>
38377>>>            Case Else // must be nfUndefined
38377>>>
38377>>>        Case End
38377>>>
38377>>>        Send SetActionButtons
38378>>>
38378>>>    End_Procedure
38379>>>
38379>>>End_Object 
