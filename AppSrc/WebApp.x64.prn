36743>>>>>>>    
36743>>>>>>>    Function Base64DecodeArr String sBase64 Returns UChar[]
36745>>>>>>>        Integer iLen
36745>>>>>>>        Pointer pBase64
36745>>>>>>>        UChar[] ucaBuffer
36746>>>>>>>        Move (Base64Decode(AddressOf(sBase64), &iLen)) to pBase64
36747>>>>>>>        If (not(pBase64)) Begin
36749>>>>>>>            Function_Return ucaBuffer
36750>>>>>>>        End
36750>>>>>>>>
36750>>>>>>>        
36750>>>>>>>        Move (ResizeArray(ucaBuffer, iLen)) to ucaBuffer
36751>>>>>>>        Move (MemCopy(AddressOf(ucaBuffer), pBase64, iLen)) to iLen
36752>>>>>>>        Move (Free(pBase64)) to iLen
36753>>>>>>>        Function_Return ucaBuffer
36754>>>>>>>    End_Function
36755>>>>>>>    
36755>>>>>>>    Function CreatePasswordHashExWithSalt UInteger uiAlgo UChar[] ucaSalt String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
36757>>>>>>>        Boolean bOk bRequireTimeCost
36757>>>>>>>        UChar[] ucaHash
36758>>>>>>>        
36758>>>>>>>        Case Begin
36758>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36760>>>>>>>                Get CNG_PBKDF2_HMAC "SHA256" (StringToUCharArray(sPassword)) ucaSalt uiOptTimeCost (&ucaHash) False to bOk
36761>>>>>>>                If (not(bOk)) Function_Return False
36764>>>>>>>                
36764>>>>>>>                Move True to bRequireTimeCost
36765>>>>>>>                Case Break
36766>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36769>>>>>>>                Get CNG_PBKDF2_HMAC "SHA512" (StringToUCharArray(sPassword)) ucaSalt uiOptTimeCost (&ucaHash) False to bOk
36770>>>>>>>                If (not(bOk)) Function_Return False
36773>>>>>>>                
36773>>>>>>>                Move True to bRequireTimeCost
36774>>>>>>>                Case Break
36775>>>>>>>            Case Else
36775>>>>>>>                Error 8710 "Invalid algorithm selected."
36776>>>>>>>>
36776>>>>>>>                Function_Return False
36777>>>>>>>        Case End
36777>>>>>>>        
36777>>>>>>>        String sSalt
36777>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36778>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return False
36781>>>>>>>        Get Base64EncodeArr ucaHash to sHash
36782>>>>>>>        If (not(SizeOfString(sHash))) Function_Return False
36785>>>>>>>        
36785>>>>>>>        If (bRequireTimeCost) Begin
36787>>>>>>>            Move (SFormat("%1$%2$%3$%4",            ;                            String(uiAlgo),         ;                            sSalt,                  ;                            String(uiOptTimeCost),  ;                            sHash)) to sHash
36788>>>>>>>        End
36788>>>>>>>>
36788>>>>>>>        Else Begin
36789>>>>>>>            Move (SFormat("%1$%2$%3",               ;                            String(uiAlgo),         ;                            sSalt,                  ;                            sHash)) to sHash
36790>>>>>>>        End
36790>>>>>>>>
36790>>>>>>>        
36790>>>>>>>        Function_Return bOk
36791>>>>>>>    End_Function
36792>>>>>>>    
36792>>>>>>>    Function CreatePasswordHashEx UInteger uiAlgo UInteger uiSaltSize String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
36794>>>>>>>        UChar[] ucaSalt
36795>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36796>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36799>>>>>>>        
36799>>>>>>>        If (num_arguments > 4) Begin
36801>>>>>>>            Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash, uiOptTimeCost))
36802>>>>>>>        End
36802>>>>>>>>
36802>>>>>>>        Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash))
36803>>>>>>>    End_Function
36804>>>>>>>    
36804>>>>>>>    Function VerifyPasswordHash String sPassword String sHash Returns Boolean
36806>>>>>>>        Boolean bRequiresTimeCost
36806>>>>>>>        UInteger uiAlgo uiTimeCost
36806>>>>>>>        Integer iBegin iEnd
36806>>>>>>>        String sSalt
36806>>>>>>>        
36806>>>>>>>        Move 1 to iBegin
36807>>>>>>>        
36807>>>>>>>        // Parse Algo
36807>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36808>>>>>>>        If (not(iEnd)) Function_Return False
36811>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiAlgo
36812>>>>>>>        
36812>>>>>>>        // Parse Salt
36812>>>>>>>        Move (iEnd + 1) to iBegin
36813>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36814>>>>>>>        If (not(iEnd)) Function_Return False
36817>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to sSalt
36818>>>>>>>        
36818>>>>>>>        Case Begin
36818>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36820>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36823>>>>>>>                Move True to bRequiresTimeCost
36824>>>>>>>                Case Break
36825>>>>>>>            Case Else
36825>>>>>>>                Error 8710 "Invalid algorithm selected."
36826>>>>>>>>
36826>>>>>>>                Function_Return False
36827>>>>>>>        Case End
36827>>>>>>>        
36827>>>>>>>        // Parse optional timecost
36827>>>>>>>        If (bRequiresTimeCost) Begin
36829>>>>>>>            Move (iEnd + 1) to iBegin
36830>>>>>>>            Move (Pos("$", sHash, iBegin)) to iEnd
36831>>>>>>>            If (not(iEnd)) Function_Return False
36834>>>>>>>            Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiTimeCost
36835>>>>>>>        End
36835>>>>>>>>
36835>>>>>>>        
36835>>>>>>>        // Parse rest hash
36835>>>>>>>        Move (iEnd + 1) to iBegin
36836>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36837>>>>>>>        If (iEnd) Function_Return False // inverse check if there are any other errors.
36840>>>>>>>        
36840>>>>>>>        // Base64Decode
36840>>>>>>>        UChar[] ucaSalt
36841>>>>>>>        Get Base64DecodeArr sSalt to ucaSalt
36842>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36845>>>>>>>        
36845>>>>>>>        // Create new hash
36845>>>>>>>        String sNewHash
36845>>>>>>>        If (bRequiresTimeCost) Begin
36847>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash, uiTimeCost))) Begin
36849>>>>>>>                Function_Return False 
36850>>>>>>>            End
36850>>>>>>>>
36850>>>>>>>        End
36850>>>>>>>>
36850>>>>>>>        Else Begin
36851>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash))) Begin
36853>>>>>>>                Function_Return False 
36854>>>>>>>            End
36854>>>>>>>>
36854>>>>>>>        End
36854>>>>>>>>
36854>>>>>>>        Function_Return (sNewHash = sHash)
36855>>>>>>>    End_Function
36856>>>>>>>    
36856>>>>>>>    Function RequiredBufferSizeEx UInteger uiAlgo UInteger uiSaltSize UInteger uiOptTimeCost Returns UBigInt
36858>>>>>>>        Boolean bRequireTimeCost
36858>>>>>>>        UBigInt ullSize
36858>>>>>>>        UChar[] ucaSalt
36859>>>>>>>        String sSalt
36859>>>>>>>        
36859>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36860>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36861>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return 0
36864>>>>>>>        
36864>>>>>>>        Case Begin
36864>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36866>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA256" to ullSize
36867>>>>>>>                Move True to bRequireTimeCost
36868>>>>>>>                Case Break
36869>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36872>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA512" to ullSize
36873>>>>>>>                Move True to bRequireTimeCost
36874>>>>>>>                Case Break
36875>>>>>>>            Case Else
36875>>>>>>>                Error 8710 "Invalid algorithm selected."
36876>>>>>>>>
36876>>>>>>>                Function_Return 0
36877>>>>>>>        Case End
36877>>>>>>>        
36877>>>>>>>        // calculate base64 in a non-floating-manner
36877>>>>>>>        Move (((ullSize + 3 -1) / 3) * 4) to ullSize
36878>>>>>>>        
36878>>>>>>>        Move (ullSize + SizeOfString(String(uiAlgo))) to ullSize
36879>>>>>>>        Move (ullSize + SizeOfString(sSalt)) to ullSize
36880>>>>>>>        If (bRequireTimeCost) Begin
36882>>>>>>>            Move (ullSize + SizeOfString(String(uiOptTimeCost))) to ullSize
36883>>>>>>>            Move (ullSize + 3 /*$*/) to ullSize
36884>>>>>>>        End
36884>>>>>>>>
36884>>>>>>>        Else Begin
36885>>>>>>>            Move (ullSize + 2 /*$*/) to ullSize
36886>>>>>>>        End
36886>>>>>>>>
36886>>>>>>>        
36886>>>>>>>        Function_Return ullSize
36887>>>>>>>    End_Function
36888>>>>>>>End_Class
36889>>>>>>>
36889>>>>>>>Class cPasswordHasher is a cObject
36890>>>>>>>    
36890>>>>>>>    Import_Class_Protocol cPasswordHasher_Mixin
36891>>>>>>>    
36891>>>>>>>    Procedure Construct_Object
36893>>>>>>>        Forward Send Construct_Object
36895>>>>>>>        
36895>>>>>>>        Property UInteger   peAlgorithm         C_PWH_PBKDF2_HMAC_SHA_512 
36896>>>>>>>        Property UInteger   puiSaltSize         16
36897>>>>>>>        
36897>>>>>>>        Property UInteger   puiOptTimeCost      420000
36898>>>>>>>    End_Procedure
36899>>>>>>>    
36899>>>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
36901>>>>>>>        Boolean bOk
36901>>>>>>>        UInteger uiAlgo
36901>>>>>>>        Get peAlgorithm to uiAlgo
36902>>>>>>>        
36902>>>>>>>        Case Begin
36902>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36904>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36907>>>>>>>                Get CreatePasswordHashEx uiAlgo (puiSaltSize(Self)) sPassword (&sHash) (puiOptTimeCost(Self)) to bOk
36908>>>>>>>                Case Break
36909>>>>>>>            Case Else
36909>>>>>>>                Error 8710 "Invalid algorithm selected."
36910>>>>>>>>
36910>>>>>>>                Function_Return False
36911>>>>>>>        Case End
36911>>>>>>>        
36911>>>>>>>        Function_Return bOk
36912>>>>>>>    End_Function
36913>>>>>>>    
36913>>>>>>>    Function RequiredBufferSize Returns UBigInt
36915>>>>>>>        UBigInt ullSize
36915>>>>>>>        UInteger uiAlgo
36915>>>>>>>        Get peAlgorithm to uiAlgo
36916>>>>>>>        
36916>>>>>>>        Case Begin
36916>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36918>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36921>>>>>>>                Get RequiredBufferSizeEx uiAlgo (puiSaltSize(Self)) (puiOptTimeCost(Self)) to ullSize
36922>>>>>>>                Case Break
36923>>>>>>>            Case Else
36923>>>>>>>                Error 8710 "Invalid algorithm selected."
36924>>>>>>>>
36924>>>>>>>                Function_Return 0
36925>>>>>>>        Case End
36925>>>>>>>        
36925>>>>>>>        Function_Return ullSize
36926>>>>>>>    End_Function
36927>>>>>>>
36927>>>>>>>End_Class
