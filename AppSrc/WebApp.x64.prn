37732>>>
37732>>>        // let's hide all buttons and then Show the ones we want
37732>>>        WebSet pbRender of oEditBtn to False
37733>>>        WebSet pbRender of oSaveBtn to False
37734>>>        WebSet pbRender of oCancelChangesBtn to False
37735>>>        WebSet pbRender of oDeleteBtn to False
37736>>>
37736>>>        If (NavigateData.bReadOnly) Begin
37738>>>            WebSet pbRender of oEditBtn to True
37739>>>        End
37739>>>>
37739>>>        Else Begin
37740>>>            WebSet pbRender of oSaveBtn to True
