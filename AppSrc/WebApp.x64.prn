37322>>>    Procedure DoLogin
37325>>>        String sLoginName sPassword sPrevStateHash
37325>>>        Boolean bResult
37325>>>        
37325>>>        WebGet psValue of oLoginName to sLoginName
37326>>>        WebGet psValue of oPassword to sPassword
37327>>>        
37327>>>        Get UserLogin of ghoWebSessionManager sLoginName sPassword to bResult
37328>>>        
37328>>>        If (bResult) Begin
37330>>>            Send Hide of oLogin
37331>>>            Send ShowHeader of ghoWebApp
37332>>>            WebSet psCSSClass of ghoWebApp to ""
37333>>>            
37333>>>            WebGet psPrevStateHash to sPrevStateHash
37334>>>            Send NavigateToStateHash of ghoWebApp sPrevStateHash True
37335>>>            
37335>>>            // clear the login values. we don't want to return the login id & password as synchronized properties....
37335>>>            WebSet psValue of oLoginName to ""
37336>>>            WebSet psValue of oPassword  to ""
37337>>>            WebSet pbVisible of oWarning to False
37338>>>        End
37338>>>>
37338>>>        Else Begin
37339>>>            WebSet pbVisible of oWarning to True
37340>>>        End
37340>>>>
37340>>>    End_Procedure
37341>>>    
37341>>>    Procedure OnSubmit
37344>>>        Send DoLogin
37345>>>    End_Procedure
37346>>>    
37346>>>    Procedure OnLoad
37349>>>        String sPrevStateHash sView
37349>>>        
37349>>>        Forward Send OnLoad
37351>>>        
37351>>>        //  Store the current state so we can go back to that later (only if it points to a different view)
37351>>>        Get StateHash of ghoWebApp to sPrevStateHash
37352>>>        Send ParseViewStateHash sPrevStateHash (&sView)
37353>>>        If (Lowercase(sView) <> Lowercase(psStateViewName(Self))) Begin
37355>>>            WebSet psPrevStateHash to sPrevStateHash
37356>>>        End
37356>>>>
37356>>>        
37356>>>    End_Procedure
