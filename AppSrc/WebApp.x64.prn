37588>>>        Get HasRecord of hoDD to bHasRecord
37589>>>
37589>>>        // let's hide all buttons and then Show the ones we want
37589>>>        WebSet pbRender of oEditBtn to False
37590>>>        WebSet pbRender of oSaveBtn to False
37591>>>        WebSet pbRender of oCancelChangesBtn to False
37592>>>        WebSet pbRender of oDeleteBtn to False
37593>>>
37593>>>        If (NavigateData.bReadOnly) Begin
37595>>>            WebSet pbRender of oEditBtn to True
37596>>>        End
37596>>>>
37596>>>        Else Begin
37597>>>            WebSet pbRender of oSaveBtn to True
37598>>>            WebSet pbRender of oCancelChangesBtn to True
37599>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37600>>>        End
