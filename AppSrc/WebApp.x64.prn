36614>>>>>>>    //
36614>>>>>>>    //  Converts the given time to an string that can be saved in the database.
36614>>>>>>>    //
36614>>>>>>>    //  Params:
36614>>>>>>>    //      dtTime  Time to convert
36614>>>>>>>    //  Returns:
36614>>>>>>>    //      String with "HH:MM:SS" format
36614>>>>>>>    //
36614>>>>>>>    Function TimeToString DateTime dtTime Returns String
36616>>>>>>>        String sHours sMinutes sSeconds
36616>>>>>>>        
36616>>>>>>>        //  Extract parts
36616>>>>>>>        Move (String(DateGetHour(dtTime))) to sHours
36617>>>>>>>        Move (String(DateGetMinute(dtTime))) to sMinutes
36618>>>>>>>        Move (String(DateGetSecond(dtTime))) to sSeconds
36619>>>>>>>        
36619>>>>>>>        //  Fill out with 0
36619>>>>>>>        If (Length(sHours) = 1) ;            Move ("0" + sHours) to sHours
36622>>>>>>>        If (Length(sMinutes) = 1) ;            Move ("0" + sMinutes) to sMinutes
36625>>>>>>>        If (Length(sSeconds) = 1) ;            Move ("0" + sSeconds) to sSeconds
36628>>>>>>>        
36628>>>>>>>        Function_Return (sHours + ":" + sMinutes + ":" + sSeconds)
36629>>>>>>>    End_Function
36630>>>>>>>    
36630>>>>>>>    //
36630>>>>>>>    //  Sets the time of the datetime variable to the time in the string.
36630>>>>>>>    //
36630>>>>>>>    //  Params:
36630>>>>>>>    //      dtTime  Datetime variable to add time to
36630>>>>>>>    //      sTimeString String with time in the format "HH:MM:SS"
36630>>>>>>>    //  Returns:
36630>>>>>>>    //      dtDateTime with the loaded time
36630>>>>>>>    //
36630>>>>>>>    Function StringToTime DateTime dtTime String sTimeString Returns DateTime
36632>>>>>>>        String sHours sMinutes sSeconds
36632>>>>>>>        
36632>>>>>>>        //  Extract parts
36632>>>>>>>        Move (Mid(sTimeString, 2, 1)) to sHours
36633>>>>>>>        Move (Mid(sTimeString, 2, 4)) to sMinutes
36634>>>>>>>        Move (Mid(sTimeString, 2, 7)) to sSeconds
36635>>>>>>>        
36635>>>>>>>        //  Set to DateTime
36635>>>>>>>        Move (DateSetHour(dtTime, (Integer(sHours)))) to dtTime
36636>>>>>>>        Move (DateSetMinute(dtTime, (Integer(sMinutes)))) to dtTime
36637>>>>>>>        Move (DateSetSecond(dtTime, (Integer(sSeconds)))) to dtTime
36638>>>>>>>        
36638>>>>>>>        Function_Return dtTime
36639>>>>>>>    End_Function
